<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#FFFFFF"
        android:elevation="1dp">

        <TextView
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="←"
            android:textSize="18sp"
            android:textColor="#0969DA"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <EditText
            android:id="@+id/notebookTitleEdit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="无标题笔记"
            android:textSize="15sp"
            android:textColor="#1F2328"
            android:textStyle="bold"
            android:maxLines="1"
            android:singleLine="true"
            android:background="@null"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <TextView
            android:id="@+id/titlePageInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#656D76" />

    </LinearLayout>

    <!-- 分屏：文件树 + PDF + AI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 左侧文件树 -->
        <LinearLayout
            android:id="@+id/fileTreePanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.18"
            android:orientation="vertical"
            android:background="#F6F8FA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/fileTreeToggle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="☰"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="笔记"
                    android:textSize="12sp"
                    android:textColor="#656D76"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/newNoteButton"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="+"
                    android:textSize="18sp"
                    android:textColor="#0969DA"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#D0D7DE" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/fileTreeRecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D0D7DE" />

        <!-- PDF 阅读区 -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#F0F0F0">

            <com.github.barteksc.pdfviewer.PDFView
                android:id="@+id/pdfView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <FrameLayout
                android:id="@+id/overlayContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|bottom"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:background="@drawable/chip_group_bg">

                <TextView
                    android:id="@+id/circleChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ 圈画"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:textColor="#1F2328"
                    android:background="@drawable/chip_inactive"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/annotateChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖍 标注"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:textColor="#1F2328"
                    android:background="@drawable/chip_inactive"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </FrameLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D0D7DE" />

        <!-- AI 侧边栏 -->
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#F6F8FA">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI 助手"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1F2328"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp">

                <Switch
                    android:id="@+id/webSearchSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="0.75"
                    android:scaleY="0.75" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌐 联网搜索"
                    android:textSize="11sp"
                    android:textColor="#656D76"
                    android:layout_marginStart="2dp" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#D0D7DE" android:layout_marginBottom="6dp" />

            <ScrollView
                android:id="@+id/chatScrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="3dp">

                <LinearLayout
                    android:id="@+id/chatContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </ScrollView>

            <ProgressBar
                android:id="@+id/loadingIndicator"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_margin="3dp" />

            <!-- 上下文标签 -->
            <HorizontalScrollView
                android:id="@+id/contextTagScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/contextTagContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp" />

            </HorizontalScrollView>

            <!-- 输入区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/edittext_bg">

                <TextView
                    android:id="@+id/imageButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🖼"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <EditText
                    android:id="@+id/questionInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="输入问题..."
                    android:textSize="13sp"
                    android:textColor="#1F2328"
                    android:textColorHint="#8B949E"
                    android:maxLines="3"
                    android:inputType="textMultiLine"
                    android:background="@null"
                    android:padding="3dp" />

                <TextView
                    android:id="@+id/sendButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="发送"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
